generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ChurchRole {
  MEMBER
  RESPO
  FINANCE
  MASTER
  CREATOR

  @@map("church_role")
}

enum MembershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
  ARCHIVED

  @@map("membership_status")
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  DEACTIVATED

  @@map("notification_delivery_status")
}

enum NotificationType {
  DAILY_VERSE
  BIRTHDAY
  ANNOUNCEMENT
  EVENT_PUBLISHED
  EVENT_REMINDER
  EVENT_CANCELLED
  PERSONAL
  STAFF_NEW_MESSAGE
  STAFF_CONFIDENTIAL_MESSAGE
  SYSTEM
  TEST

  @@map("notification_type")
}

enum NotificationAudienceType {
  ALL_ACTIVE_MEMBERS
  ROLE
  INDIVIDUAL
  ANONYMOUS_DAILY_VERSE
  STAFF_GENERAL
  STAFF_CONFIDENTIAL

  @@map("notification_audience_type")
}

enum NotificationCampaignStatus {
  DRAFT
  SCHEDULED
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED

  @@map("notification_campaign_status")
}

enum PushDeliveryStatus {
  PENDING
  PROCESSING
  ACCEPTED
  RETRY
  FAILED
  EXPIRED
  SKIPPED

  @@map("push_delivery_status")
}

enum ContentVisibility {
  PUBLIC
  MEMBERS_ONLY

  @@map("content_visibility")
}

enum EventStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  CANCELLED
  ARCHIVED

  @@map("event_status")
}

enum GalleryAlbumStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("gallery_album_status")
}

enum ContactMessageSource {
  PUBLIC_CONTACT
  MEMBER_PORTAL

  @@map("contact_message_source")
}

enum MessageConfidentiality {
  GENERAL
  PASTORAL_CONFIDENTIAL

  @@map("message_confidentiality")
}

enum ContactMessageStatus {
  NEW
  IN_PROGRESS
  ANSWERED
  ARCHIVED

  @@map("contact_message_status")
}

enum MessageDeliveryStatus {
  INTERNAL_NOTE
  DRAFT
  SENT
  FAILED

  @@map("message_delivery_status")
}

enum AnnouncementCategory {
  GENERAL
  EMPLOI
  MARIAGE
  BAPTEME
  EVENEMENT
  BON_PLAN
  URGENT

  @@map("announcement_category")
}

enum AnnouncementStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED

  @@map("announcement_status")
}

enum DonationFrequency {
  ONE_TIME
  MONTHLY

  @@map("donation_frequency")
}

enum DonationSource {
  ONLINE
  DIRECT

  @@map("donation_source")
}

enum DirectDonationKind {
  IDENTIFIED
  ANONYMOUS_COLLECTION

  @@map("direct_donation_kind")
}

enum DirectDonationStatus {
  RECORDED
  VERIFIED
  CANCELLED

  @@map("direct_donation_status")
}

enum DonationCheckoutStatus {
  CREATED
  OPEN
  COMPLETED
  EXPIRED
  FAILED
  CANCELLED

  @@map("donation_checkout_status")
}

enum DonationStatus {
  PENDING
  SUCCEEDED
  FAILED
  PARTIALLY_REFUNDED
  REFUNDED
  DISPUTED
  CANCELLED

  @@map("donation_status")
}

enum RecurringDonationStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED

  @@map("recurring_donation_status")
}

enum DonationRefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED

  @@map("donation_refund_status")
}

enum StripeWebhookProcessingStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  IGNORED
  FAILED

  @@map("stripe_webhook_processing_status")
}

enum DailyVerseScheduleStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
  FAILED

  @@map("daily_verse_schedule_status")
}

model AppUser {
  id                 String           @id @default(cuid())
  clerkUserId        String           @unique @map("clerk_user_id")
  email              String
  firstName          String?          @map("first_name")
  lastName           String?          @map("last_name")
  imageUrl           String?          @map("image_url")
  stripeCustomerId   String?          @unique @map("stripe_customer_id")
  role               ChurchRole       @default(MEMBER)
  membershipStatus   MembershipStatus @default(PENDING) @map("membership_status")
  onboardingComplete Boolean          @default(false) @map("onboarding_complete")
  archivedAt         DateTime?        @map("archived_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  profile                       MemberProfile?
  privateDetails                MemberPrivateDetails?
  notificationPreference        NotificationPreference?
  pushSubscriptions             PushSubscription[]
  approvedProfiles              MemberProfile[]         @relation("MemberApprover")
  adminAuditLogs                AdminAuditLog[]         @relation("AuditActor")
  createdEvents                 ChurchEvent[]           @relation("EventCreator")
  updatedEvents                 ChurchEvent[]           @relation("EventUpdater")
  createdGalleryAlbums          GalleryAlbum[]          @relation("GalleryAlbumCreator")
  uploadedGalleryItems          GalleryItem[]           @relation("GalleryItemUploader")
  sentContactMessages           ContactMessage[]        @relation("ContactMessageSender")
  assignedContactMessages       ContactMessage[]        @relation("ContactMessageAssignee")
  messageReplies                MessageReply[]          @relation("MessageReplyAuthor")
  messageInternalNotes          MessageInternalNote[]   @relation("MessageNoteAuthor")
  authoredAnnouncements         Announcement[]          @relation("AnnouncementAuthor")
  updatedAnnouncements          Announcement[]          @relation("AnnouncementUpdater")
  announcementReads             AnnouncementRead[]
  createdNotificationCampaigns  NotificationCampaign[]  @relation("NotificationCampaignCreator")
  targetedNotificationCampaigns NotificationCampaign[]  @relation("NotificationCampaignTarget")
  notificationRecipients        NotificationRecipient[]
  donationCheckouts             DonationCheckout[]      @relation("DonationCheckoutUser")
  donations                     Donation[]              @relation("DonationUser")
  recurringDonations            RecurringDonation[]     @relation("RecurringDonationUser")
  enteredDirectDonations        Donation[]              @relation("DonationEnteredBy")
  verifiedDirectDonations       Donation[]              @relation("DonationVerifiedBy")
  cancelledDirectDonations      Donation[]              @relation("DonationCancelledBy")
  bibleFavorites                BibleFavorite[]
  bibleNotes                    BibleNote[]
  createdDailyVerseSchedules    DailyVerseSchedule[]    @relation("DailyVerseScheduleCreator")
  updatedDailyVerseSchedules    DailyVerseSchedule[]    @relation("DailyVerseScheduleUpdater")
  cancelledDailyVerseSchedules  DailyVerseSchedule[]    @relation("DailyVerseScheduleCanceller")
  sentDailyVerseSchedules       DailyVerseSchedule[]    @relation("DailyVerseScheduleSender")

  @@index([email])
  @@index([role])
  @@index([membershipStatus])
  @@map("app_users")
}

model MemberProfile {
  id           String    @id @default(cuid())
  userId       String    @unique @map("user_id")
  memberNumber Int?      @unique @map("member_number")
  memberId     String?   @unique @map("member_id")
  displayName  String?   @map("display_name")
  avatarUrl    String?   @map("avatar_url")
  joinedAt     DateTime? @map("joined_at")
  approvedAt   DateTime? @map("approved_at")
  approvedById String?   @map("approved_by_id")
  suspendedAt  DateTime? @map("suspended_at")
  rejectedAt   DateTime? @map("rejected_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Restrict)
  approvedBy AppUser? @relation("MemberApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([approvedById])
  @@map("member_profiles")
}

model MemberPrivateDetails {
  id           String    @id @default(cuid())
  userId       String    @unique @map("user_id")
  phone        String?
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  addressLine1 String?   @map("address_line_1")
  addressLine2 String?   @map("address_line_2")
  postalCode   String?   @map("postal_code")
  city         String?
  countryCode  String    @default("FR") @map("country_code")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("member_private_details")
}

model NotificationPreference {
  id                                 String   @id @default(cuid())
  userId                             String   @unique @map("user_id")
  dailyVerseEnabled                  Boolean  @default(true) @map("daily_verse_enabled")
  privateBirthdayGreetingEnabled     Boolean  @default(true) @map("private_birthday_greeting_enabled")
  communityBirthdayVisibilityEnabled Boolean  @default(true) @map("community_birthday_visibility_enabled")
  announcementsEnabled               Boolean  @default(true) @map("announcements_enabled")
  eventsEnabled                      Boolean  @default(true) @map("events_enabled")
  donationNotificationsEnabled       Boolean  @default(true) @map("donation_notifications_enabled")
  pushEnabled                        Boolean  @default(true) @map("push_enabled")
  dailyVersePushEnabled              Boolean  @default(true) @map("daily_verse_push_enabled")
  birthdayPushEnabled                Boolean  @default(true) @map("birthday_push_enabled")
  announcementPushEnabled            Boolean  @default(true) @map("announcement_push_enabled")
  eventPushEnabled                   Boolean  @default(true) @map("event_push_enabled")
  personalPushEnabled                Boolean  @default(true) @map("personal_push_enabled")
  staffMessagePushEnabled            Boolean  @default(true) @map("staff_message_push_enabled")
  timezone                           String   @default("Europe/Paris")
  createdAt                          DateTime @default(now()) @map("created_at")
  updatedAt                          DateTime @updatedAt @map("updated_at")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("notification_preferences")
}

model PushSubscription {
  id                         String    @id @default(cuid())
  userId                     String?   @map("user_id")
  endpoint                   String    @unique
  p256dh                     String
  auth                       String
  deviceName                 String?   @map("device_name")
  userAgent                  String?   @map("user_agent")
  locale                     String?
  timezone                   String    @default("Europe/Paris")
  isActive                   Boolean   @default(true) @map("is_active")
  anonymousDailyVerseEnabled Boolean   @default(true) @map("anonymous_daily_verse_enabled")
  lastSentAt                 DateTime? @map("last_sent_at")
  lastSeenAt                 DateTime? @map("last_seen_at")
  lastSuccessAt              DateTime? @map("last_success_at")
  failureCount               Int       @default(0) @map("failure_count")
  revokedAt                  DateTime? @map("revoked_at")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  user             AppUser?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  logs             NotificationLog[]
  deliveryAttempts PushDeliveryAttempt[]

  @@index([userId])
  @@index([isActive])
  @@index([userId, isActive])
  @@map("push_subscriptions")
}

model DailyBibleVerse {
  id          String   @id @default(cuid())
  dayOfYear   Int      @unique @map("day_of_year")
  reference   String
  text        String
  translation String
  theme       String?
  source      String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("daily_bible_verses")
}

model BibleFavorite {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  book              String
  chapter           Int
  verseStart        Int      @map("verse_start")
  verseEnd          Int      @map("verse_end")
  reference         String
  verseTextSnapshot String   @map("verse_text_snapshot")
  translation       String
  createdAt         DateTime @default(now()) @map("created_at")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, book, chapter, verseStart, verseEnd, translation])
  @@index([userId, createdAt])
  @@index([book, chapter, verseStart])
  @@map("bible_favorites")
}

model BibleNote {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  book        String
  chapter     Int
  verseStart  Int      @map("verse_start")
  verseEnd    Int      @map("verse_end")
  reference   String
  translation String
  content     String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, book, chapter, verseStart, verseEnd, translation])
  @@index([userId, updatedAt])
  @@index([book, chapter, verseStart])
  @@map("bible_notes")
}

model DailyVerseSchedule {
  id                String                   @id @default(cuid())
  localDate         String                   @map("local_date")
  notificationTime  String                   @map("notification_time")
  scheduledFor      DateTime?                @map("scheduled_for")
  status            DailyVerseScheduleStatus @default(DRAFT)
  book              String
  chapter           Int
  verseStart        Int                      @map("verse_start")
  verseEnd          Int                      @map("verse_end")
  reference         String
  verseText         String                   @map("verse_text")
  translation       String
  theme             String?
  dedupeKey         String                   @unique @map("dedupe_key")
  failureCode       String?                  @map("failure_code")
  sentAt            DateTime?                @map("sent_at")
  cancelledAt       DateTime?                @map("cancelled_at")
  createdByUserId   String                   @map("created_by_user_id")
  updatedByUserId   String?                  @map("updated_by_user_id")
  cancelledByUserId String?                  @map("cancelled_by_user_id")
  sentByUserId      String?                  @map("sent_by_user_id")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  createdBy   AppUser  @relation("DailyVerseScheduleCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy   AppUser? @relation("DailyVerseScheduleUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  cancelledBy AppUser? @relation("DailyVerseScheduleCanceller", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  sentBy      AppUser? @relation("DailyVerseScheduleSender", fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@index([status, scheduledFor])
  @@index([localDate])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([cancelledByUserId])
  @@index([sentByUserId])
  @@map("daily_verse_schedules")
}

model NotificationLog {
  id                 String                     @id @default(cuid())
  userId             String?                    @map("user_id")
  pushSubscriptionId String?                    @map("push_subscription_id")
  notificationType   String                     @map("notification_type")
  title              String?
  deliveryStatus     NotificationDeliveryStatus @default(PENDING) @map("delivery_status")
  errorMessage       String?                    @map("error_message")
  deduplicationKey   String?                    @unique @map("deduplication_key")
  sentAt             DateTime?                  @map("sent_at")
  createdAt          DateTime                   @default(now()) @map("created_at")

  pushSubscription PushSubscription? @relation(fields: [pushSubscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([notificationType])
  @@map("notification_logs")
}

model NotificationCampaign {
  id                  String                     @id @default(cuid())
  type                NotificationType
  title               String
  body                String
  targetUrl           String                     @map("target_url")
  iconUrl             String?                    @map("icon_url")
  imageUrl            String?                    @map("image_url")
  tag                 String?
  audienceType        NotificationAudienceType   @map("audience_type")
  targetRole          ChurchRole?                @map("target_role")
  targetUserId        String?                    @map("target_user_id")
  sourceType          String?                    @map("source_type")
  sourceId            String?                    @map("source_id")
  status              NotificationCampaignStatus @default(PENDING)
  scheduledFor        DateTime?                  @map("scheduled_for")
  processingStartedAt DateTime?                  @map("processing_started_at")
  completedAt         DateTime?                  @map("completed_at")
  cancelledAt         DateTime?                  @map("cancelled_at")
  createdByUserId     String?                    @map("created_by_user_id")
  dedupeKey           String                     @unique @map("dedupe_key")
  metadata            Json?
  createdAt           DateTime                   @default(now()) @map("created_at")
  updatedAt           DateTime                   @updatedAt @map("updated_at")

  createdBy        AppUser?                @relation("NotificationCampaignCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  targetUser       AppUser?                @relation("NotificationCampaignTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  recipients       NotificationRecipient[]
  deliveryAttempts PushDeliveryAttempt[]

  @@index([status, scheduledFor])
  @@index([type])
  @@index([audienceType])
  @@index([targetRole])
  @@index([targetUserId])
  @@index([sourceType, sourceId])
  @@index([createdByUserId])
  @@map("notification_campaigns")
}

model NotificationRecipient {
  id         String    @id @default(cuid())
  campaignId String    @map("campaign_id")
  userId     String    @map("user_id")
  readAt     DateTime? @map("read_at")
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  campaign         NotificationCampaign  @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  user             AppUser               @relation(fields: [userId], references: [id], onDelete: Restrict)
  deliveryAttempts PushDeliveryAttempt[]

  @@unique([campaignId, userId])
  @@index([userId, readAt])
  @@index([campaignId])
  @@map("notification_recipients")
}

model PushDeliveryAttempt {
  id                 String             @id @default(cuid())
  recipientId        String?            @map("recipient_id")
  campaignId         String             @map("campaign_id")
  pushSubscriptionId String             @map("push_subscription_id")
  status             PushDeliveryStatus @default(PENDING)
  attemptNumber      Int                @default(1) @map("attempt_number")
  nextAttemptAt      DateTime?          @map("next_attempt_at")
  acceptedAt         DateTime?          @map("accepted_at")
  failedAt           DateTime?          @map("failed_at")
  responseStatusCode Int?               @map("response_status_code")
  safeErrorCode      String?            @map("safe_error_code")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  recipient        NotificationRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  campaign         NotificationCampaign   @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  pushSubscription PushSubscription       @relation(fields: [pushSubscriptionId], references: [id], onDelete: Restrict)

  @@unique([campaignId, pushSubscriptionId, attemptNumber])
  @@index([status, nextAttemptAt])
  @@index([campaignId, status])
  @@index([recipientId])
  @@index([pushSubscriptionId])
  @@map("push_delivery_attempts")
}

model AdminAuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?  @map("actor_user_id")
  actorMemberId String?  @map("actor_member_id")
  action        String
  entityType    String   @map("entity_type")
  entityId      String?  @map("entity_id")
  summary       String?
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  actor AppUser? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model ChurchSetting {
  id             String   @id @default("default")
  churchName     String   @default("MegVie Paris") @map("church_name")
  shortName      String   @default("MVP") @map("short_name")
  memberIdPrefix String   @default("Mv") @map("member_id_prefix")
  memberIdSuffix String   @default("P") @map("member_id_suffix")
  timezone       String   @default("Europe/Paris")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("church_settings")
}

model ChurchEvent {
  id                   String            @id @default(cuid())
  title                String
  slug                 String            @unique
  shortDescription     String?           @map("short_description")
  description          String?
  startsAt             DateTime          @map("starts_at")
  endsAt               DateTime?         @map("ends_at")
  timezone             String            @default("Europe/Paris")
  locationName         String?           @map("location_name")
  address              String?
  mapUrl               String?           @map("map_url")
  registrationUrl      String?           @map("registration_url")
  coverImageUrl        String?           @map("cover_image_url")
  coverImageStorageKey String?           @map("cover_image_storage_key")
  visibility           ContentVisibility @default(PUBLIC)
  status               EventStatus       @default(DRAFT)
  publishAt            DateTime?         @map("publish_at")
  publishedAt          DateTime?         @map("published_at")
  createdByUserId      String            @map("created_by_user_id")
  updatedByUserId      String?           @map("updated_by_user_id")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  archivedAt           DateTime?         @map("archived_at")

  createdBy       AppUser    @relation("EventCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy       AppUser?   @relation("EventUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  directDonations Donation[] @relation("EventDirectDonations")

  @@index([status])
  @@index([visibility])
  @@index([startsAt])
  @@index([createdByUserId])
  @@map("church_events")
}

model GalleryAlbum {
  id                   String             @id @default(cuid())
  title                String
  slug                 String             @unique
  description          String?
  coverImageUrl        String?            @map("cover_image_url")
  coverImageStorageKey String?            @map("cover_image_storage_key")
  status               GalleryAlbumStatus @default(DRAFT)
  eventDate            DateTime?          @map("event_date") @db.Date
  createdByUserId      String             @map("created_by_user_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  archivedAt           DateTime?          @map("archived_at")

  createdBy AppUser       @relation("GalleryAlbumCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  items     GalleryItem[]

  @@index([status])
  @@index([eventDate])
  @@index([createdByUserId])
  @@map("gallery_albums")
}

model GalleryItem {
  id               String    @id @default(cuid())
  albumId          String    @map("album_id")
  imageUrl         String    @map("image_url")
  storageKey       String?   @map("storage_key")
  caption          String?
  altText          String?   @map("alt_text")
  sortOrder        Int       @default(0) @map("sort_order")
  uploadedByUserId String    @map("uploaded_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  archivedAt       DateTime? @map("archived_at")

  album      GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Restrict)
  uploadedBy AppUser      @relation("GalleryItemUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([albumId])
  @@index([uploadedByUserId])
  @@map("gallery_items")
}

model ContactMessage {
  id               String                 @id @default(cuid())
  senderUserId     String?                @map("sender_user_id")
  senderName       String                 @map("sender_name")
  senderEmail      String                 @map("sender_email")
  senderPhone      String?                @map("sender_phone")
  subject          String
  category         String                 @default("GENERAL")
  body             String
  source           ContactMessageSource   @default(PUBLIC_CONTACT)
  confidentiality  MessageConfidentiality @default(GENERAL)
  status           ContactMessageStatus   @default(NEW)
  assignedToUserId String?                @map("assigned_to_user_id")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  firstReadAt      DateTime?              @map("first_read_at")
  answeredAt       DateTime?              @map("answered_at")
  archivedAt       DateTime?              @map("archived_at")

  sender     AppUser?              @relation("ContactMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  assignedTo AppUser?              @relation("ContactMessageAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  replies    MessageReply[]
  notes      MessageInternalNote[]

  @@index([senderUserId])
  @@index([assignedToUserId])
  @@index([status])
  @@index([confidentiality])
  @@index([createdAt])
  @@map("contact_messages")
}

model MessageReply {
  id                String                @id @default(cuid())
  messageId         String                @map("message_id")
  authorUserId      String                @map("author_user_id")
  body              String
  deliveryStatus    MessageDeliveryStatus @default(DRAFT) @map("delivery_status")
  externalMessageId String?               @map("external_message_id")
  createdAt         DateTime              @default(now()) @map("created_at")
  sentAt            DateTime?             @map("sent_at")
  failedAt          DateTime?             @map("failed_at")
  failureReason     String?               @map("failure_reason")

  message ContactMessage @relation(fields: [messageId], references: [id], onDelete: Restrict)
  author  AppUser        @relation("MessageReplyAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([messageId])
  @@index([authorUserId])
  @@map("message_replies")
}

model MessageInternalNote {
  id           String   @id @default(cuid())
  messageId    String   @map("message_id")
  authorUserId String   @map("author_user_id")
  body         String
  createdAt    DateTime @default(now()) @map("created_at")

  message ContactMessage @relation(fields: [messageId], references: [id], onDelete: Restrict)
  author  AppUser        @relation("MessageNoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([messageId])
  @@index([authorUserId])
  @@map("message_internal_notes")
}

model Announcement {
  id                   String               @id @default(cuid())
  title                String
  slug                 String               @unique
  summary              String?
  body                 String
  category             AnnouncementCategory @default(GENERAL)
  coverImageUrl        String?              @map("cover_image_url")
  coverImageStorageKey String?              @map("cover_image_storage_key")
  externalUrl          String?              @map("external_url")
  visibility           ContentVisibility    @default(MEMBERS_ONLY)
  status               AnnouncementStatus   @default(DRAFT)
  publishAt            DateTime?            @map("publish_at")
  publishedAt          DateTime?            @map("published_at")
  expiresAt            DateTime?            @map("expires_at")
  authorUserId         String               @map("author_user_id")
  updatedByUserId      String?              @map("updated_by_user_id")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  archivedAt           DateTime?            @map("archived_at")

  author    AppUser            @relation("AnnouncementAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)
  updatedBy AppUser?           @relation("AnnouncementUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  reads     AnnouncementRead[]

  @@index([status])
  @@index([visibility])
  @@index([category])
  @@index([publishAt])
  @@index([authorUserId])
  @@map("announcements")
}

model AnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String   @map("announcement_id")
  userId         String   @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Restrict)
  user         AppUser      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([announcementId, userId])
  @@index([userId])
  @@map("announcement_reads")
}

model DonationCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  checkouts          DonationCheckout[]
  donations          Donation[]
  recurringDonations RecurringDonation[]

  @@index([isActive, sortOrder])
  @@map("donation_categories")
}

model DonationCheckout {
  id                      String                 @id @default(cuid())
  userId                  String?                @map("user_id")
  memberIdSnapshot        String?                @map("member_id_snapshot")
  categoryId              String                 @map("category_id")
  frequency               DonationFrequency
  amountCents             Int                    @map("amount_cents")
  currency                String                 @default("eur")
  donorNameSnapshot       String?                @map("donor_name_snapshot")
  donorEmailSnapshot      String?                @map("donor_email_snapshot")
  status                  DonationCheckoutStatus @default(CREATED)
  stripeCheckoutSessionId String?                @unique @map("stripe_checkout_session_id")
  stripeCustomerId        String?                @map("stripe_customer_id")
  stripeSubscriptionId    String?                @map("stripe_subscription_id")
  stripePaymentIntentId   String?                @map("stripe_payment_intent_id")
  livemode                Boolean                @default(false)
  expiresAt               DateTime?              @map("expires_at")
  completedAt             DateTime?              @map("completed_at")
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime               @updatedAt @map("updated_at")

  user      AppUser?         @relation("DonationCheckoutUser", fields: [userId], references: [id], onDelete: SetNull)
  category  DonationCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  donations Donation[]

  @@index([userId, createdAt])
  @@index([categoryId])
  @@index([status, createdAt])
  @@index([frequency])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@map("donation_checkouts")
}

model Donation {
  id                      String                @id @default(cuid())
  userId                  String?               @map("user_id")
  memberIdSnapshot        String?               @map("member_id_snapshot")
  checkoutId              String?               @map("checkout_id")
  recurringDonationId     String?               @map("recurring_donation_id")
  categoryId              String                @map("category_id")
  frequency               DonationFrequency
  source                  DonationSource        @default(ONLINE)
  status                  DonationStatus        @default(PENDING)
  amountCents             Int                   @map("amount_cents")
  refundedAmountCents     Int                   @default(0) @map("refunded_amount_cents")
  currency                String                @default("eur")
  donorNameSnapshot       String?               @map("donor_name_snapshot")
  donorEmailSnapshot      String?               @map("donor_email_snapshot")
  directKind              DirectDonationKind?   @map("direct_kind")
  directStatus            DirectDonationStatus? @map("direct_status")
  receivedAt              DateTime?             @map("received_at")
  eventId                 String?               @map("event_id")
  collectionLabel         String?               @map("collection_label")
  internalNote            String?               @map("internal_note")
  manualReference         String?               @map("manual_reference")
  enteredByUserId         String?               @map("entered_by_user_id")
  verifiedByUserId        String?               @map("verified_by_user_id")
  verifiedAt              DateTime?             @map("verified_at")
  cancelledByUserId       String?               @map("cancelled_by_user_id")
  cancelledAt             DateTime?             @map("cancelled_at")
  cancellationReason      String?               @map("cancellation_reason")
  correctionReason        String?               @map("correction_reason")
  replacesDonationId      String?               @map("replaces_donation_id")
  directEntryRequestId    String?               @unique @map("direct_entry_request_id")
  stripeCustomerId        String?               @map("stripe_customer_id")
  stripeCheckoutSessionId String?               @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?               @unique @map("stripe_payment_intent_id")
  stripeInvoiceId         String?               @unique @map("stripe_invoice_id")
  stripeChargeId          String?               @unique @map("stripe_charge_id")
  stripeReceiptUrl        String?               @map("stripe_receipt_url")
  stripeHostedInvoiceUrl  String?               @map("stripe_hosted_invoice_url")
  stripeInvoicePdfUrl     String?               @map("stripe_invoice_pdf_url")
  failureCode             String?               @map("failure_code")
  livemode                Boolean               @default(false)
  donatedAt               DateTime?             @map("donated_at")
  failedAt                DateTime?             @map("failed_at")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")

  user                AppUser?           @relation("DonationUser", fields: [userId], references: [id], onDelete: SetNull)
  checkout            DonationCheckout?  @relation(fields: [checkoutId], references: [id], onDelete: SetNull)
  recurringDonation   RecurringDonation? @relation(fields: [recurringDonationId], references: [id], onDelete: SetNull)
  category            DonationCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  event               ChurchEvent?       @relation("EventDirectDonations", fields: [eventId], references: [id], onDelete: SetNull)
  enteredBy           AppUser?           @relation("DonationEnteredBy", fields: [enteredByUserId], references: [id], onDelete: SetNull)
  verifiedBy          AppUser?           @relation("DonationVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  cancelledBy         AppUser?           @relation("DonationCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  replacesDonation    Donation?          @relation("DonationCorrection", fields: [replacesDonationId], references: [id], onDelete: SetNull)
  replacedByDonations Donation[]         @relation("DonationCorrection")
  refunds             DonationRefund[]

  @@index([userId, donatedAt])
  @@index([categoryId, donatedAt])
  @@index([status, donatedAt])
  @@index([frequency, donatedAt])
  @@index([source])
  @@index([directStatus])
  @@index([directKind])
  @@index([receivedAt])
  @@index([eventId])
  @@index([enteredByUserId])
  @@index([verifiedByUserId])
  @@index([cancelledByUserId])
  @@index([source, directStatus, receivedAt])
  @@index([source, categoryId, receivedAt])
  @@index([stripeCustomerId])
  @@index([stripeCheckoutSessionId])
  @@index([createdAt])
  @@map("donations")
}

model RecurringDonation {
  id                   String                  @id @default(cuid())
  userId               String                  @map("user_id")
  memberIdSnapshot     String?                 @map("member_id_snapshot")
  categoryId           String                  @map("category_id")
  amountCents          Int                     @map("amount_cents")
  currency             String                  @default("eur")
  status               RecurringDonationStatus @default(INCOMPLETE)
  stripeCustomerId     String                  @map("stripe_customer_id")
  stripeSubscriptionId String                  @unique @map("stripe_subscription_id")
  stripePriceId        String?                 @map("stripe_price_id")
  stripeProductId      String?                 @map("stripe_product_id")
  currentPeriodStart   DateTime?               @map("current_period_start")
  currentPeriodEnd     DateTime?               @map("current_period_end")
  cancelAtPeriodEnd    Boolean                 @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?               @map("canceled_at")
  endedAt              DateTime?               @map("ended_at")
  livemode             Boolean                 @default(false)
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  user      AppUser          @relation("RecurringDonationUser", fields: [userId], references: [id], onDelete: Restrict)
  category  DonationCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  donations Donation[]

  @@index([userId, status])
  @@index([categoryId])
  @@index([status])
  @@index([stripeCustomerId])
  @@index([createdAt])
  @@map("recurring_donations")
}

model DonationRefund {
  id             String               @id @default(cuid())
  donationId     String               @map("donation_id")
  stripeRefundId String               @unique @map("stripe_refund_id")
  amountCents    Int                  @map("amount_cents")
  currency       String               @default("eur")
  status         DonationRefundStatus @default(PENDING)
  reason         String?
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  donation Donation @relation(fields: [donationId], references: [id], onDelete: Restrict)

  @@index([donationId])
  @@index([status])
  @@map("donation_refunds")
}

model StripeWebhookEvent {
  id                  String                        @id @default(cuid())
  stripeEventId       String                        @unique @map("stripe_event_id")
  eventType           String                        @map("event_type")
  stripeObjectId      String?                       @map("stripe_object_id")
  livemode            Boolean                       @default(false)
  apiVersion          String?                       @map("api_version")
  processingStatus    StripeWebhookProcessingStatus @default(RECEIVED) @map("processing_status")
  attemptCount        Int                           @default(0) @map("attempt_count")
  lastErrorCode       String?                       @map("last_error_code")
  receivedAt          DateTime                      @default(now()) @map("received_at")
  processingStartedAt DateTime?                     @map("processing_started_at")
  processedAt         DateTime?                     @map("processed_at")
  failedAt            DateTime?                     @map("failed_at")
  createdAt           DateTime                      @default(now()) @map("created_at")
  updatedAt           DateTime                      @updatedAt @map("updated_at")

  @@index([processingStatus, receivedAt])
  @@index([eventType])
  @@index([stripeObjectId])
  @@map("stripe_webhook_events")
}
